{
  "name": "@concilia/agente-local",
  "version": "0.5.4",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": "build/index.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "bundle": "tsx scripts/bundle.ts",
    "bundle:inspect": "tsx scripts/bundle-inspect.ts",
    "package:win": "tsx scripts/package-win-node.ts",
    "package:win-pkg": "tsx scripts/package-win.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@concilia/shared": "workspace:*",
    "node-firebird": "^2.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@yao-pkg/pkg": "^6.5.1",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pkg": {
    "scripts": "build/index.cjs",
    "targets": ["node22-win-x64"],
    "outputPath": "release"
  }
}
